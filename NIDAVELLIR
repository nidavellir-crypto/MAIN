local function applyAcc(char, args)
    if not char or not args then return end

    task.spawn(function()
        local head = char:WaitForChild("Head", 5)
        if not head then return end
        
        task.wait(0.8)
        
        for _, v in ipairs(char:GetChildren()) do 
            if v.Name == "NidavellirCustomAcc" then v:Destroy() end 
        end

        local mID = args[1]
        local tID = args[2]
        local yOff = args[3] or 0
        local zOff = args[4] or 0
        local scale = args[5] or Vector3.new(1,1,1)
        local fireData = args[6]

        local handle = Instance.new("Part")
        handle.Name = "NidavellirCustomAcc"
        handle.Size = Vector3.new(1, 1, 1)
        handle.CanCollide = false
        handle.Massless = true
        handle.Parent = char

        local mesh = Instance.new("SpecialMesh", handle)
        mesh.MeshType = Enum.MeshType.FileMesh
        mesh.MeshId = mID:find("rbxassetid") and mID or "rbxassetid://" .. mID
        mesh.TextureId = tID:find("rbxassetid") and tID or "rbxassetid://" .. tID
        mesh.Scale = scale

        if fireData then
            local fire = Instance.new("Fire", handle)
            fire.Size = 4
            fire.Heat = fireData.Heat or 5
            fire.Color = fireData.Color or Color3.fromRGB(52, 206, 236)
            fire.SecondaryColor = fire.Color
        end

        if mID == "24101267" or mID == "rbxassetid://24101267" then
            local s1 = Instance.new("Sound", handle) s1.SoundId = "rbxassetid://24111685" s1.Volume = 1
            local s2 = Instance.new("Sound", handle) s2.SoundId = "rbxassetid://24111782" s2.Volume = 1
            local s3 = Instance.new("Sound", handle) s3.SoundId = "rbxassetid://24111798" s3.Volume = 1
            task.spawn(function()
                while handle and handle.Parent do
                    local choice = math.random(1, 3)
                    if choice == 1 then s1:Play() elseif choice == 2 then s2:Play() else s3:Play() end
                    task.wait(math.random(3, 7))
                end
            end)
        end

        local weld = Instance.new("Weld", handle)
        weld.Part0 = handle
        weld.Part1 = head
        weld.C0 = CFrame.new(0, yOff, zOff)
    end)
end

-- === OUTFIT ENFORCER ===
local function applyOutfit(sID, pID, resetMode, targetChar)
    OutfitToken = OutfitToken + 1
    local myToken = OutfitToken
    IsResetState = resetMode
    CurrentShirt = (resetMode or sID:find("rbxassetid") or sID:find("rbxthumb")) and sID or "rbxthumb://type=Asset&id="..sID.."&w=420&h=420"
    CurrentPants = (resetMode or pID:find("rbxassetid") or pID:find("rbxthumb")) and pID or "rbxthumb://type=Asset&id="..pID.."&w=420&h=420"
    
    local function enforce(char)
        task.spawn(function()
            local start = tick()
            while tick() - start < 4 do
                if OutfitToken ~= myToken or not char or not char.Parent then break end
                local s = char:FindFirstChildOfClass("Shirt") or Instance.new("Shirt", char)
                local p = char:FindFirstChildOfClass("Pants") or Instance.new("Pants", char)
                s.ShirtTemplate = CurrentShirt
                p.PantsTemplate = CurrentPants
    
                for _, obj in ipairs(char:GetChildren()) do
                    if obj:IsA("GraphicShirt") then obj:Destroy() end
                    if obj:IsA("Shirt") and obj ~= s then obj:Destroy() end
                    if obj:IsA("Pants") and obj ~= p then obj:Destroy() end
                end

                local targetTrans = IsResetState and 0 or 1
                for _, obj in ipairs(char:GetChildren()) do
                    if obj.Name == "NidavellirCustomAcc" then continue end
                    
                    if obj:IsA("BasePart") then
                        if obj.Name == "Head" then
                            obj.Transparency = IsHeadless and 1 or 0
                            if obj:FindFirstChild("face") then obj.face.Transparency = IsHeadless and 1 or 0 end
                        elseif obj.Name:find("Left") and (obj.Name:find("Leg") or obj.Name:find("Foot")) then
                            obj.Transparency = IsLeftLegless and 1 or 0
                        end
                    elseif obj:IsA("Accessory") then
                        for _, ap in ipairs(obj:GetDescendants()) do
                            if ap:IsA("BasePart") or ap:IsA("Decal") then ap.Transparency = targetTrans end
                        end
                    end
                end
                applyLevelHide()
                applyUIHide()
                task.wait(0.1)
            end
        end)
    end
    
    local charToUse = targetChar or Player.Character
    if charToUse then enforce(charToUse) end
end

-- === SKIN ENFORCER ===
local function applySkin(color, resetMode, targetChar)
    SkinToken = SkinToken + 1
    local myToken = SkinToken
    CurrentSkinColor = color
    local function enforce(char)
        task.spawn(function()
            local start = tick()
            while tick() - start < 4 do
                 if SkinToken ~= myToken or not char or not char.Parent then break end
                if not resetMode and CurrentSkinColor then
                    local bc = char:FindFirstChildOfClass("BodyColors")
                    if not bc then
                        bc = Instance.new("BodyColors")
                        bc.Parent = char
                    end
                    bc.HeadColor3 = CurrentSkinColor
                    bc.LeftArmColor3 = CurrentSkinColor
                    bc.RightArmColor3 = CurrentSkinColor
                    bc.LeftLegColor3 = CurrentSkinColor
                    bc.RightLegColor3 = CurrentSkinColor
                    bc.TorsoColor3 = CurrentSkinColor
                elseif resetMode and OriginalBodyColors then
                    local bc = char:FindFirstChildOfClass("BodyColors")
                    if bc then bc:Destroy() end
                    OriginalBodyColors:Clone().Parent = char
                    break
                end
                task.wait(0.1)
            end
        end)
    end
    local charToUse = targetChar or Player.Character
    if charToUse then enforce(charToUse) end
end

