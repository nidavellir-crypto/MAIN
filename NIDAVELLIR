function loadSavedButtons()
    for _, btn in ipairs(SavedUIRefs) do btn:Destroy() end
    SavedUIRefs = {}
    for i, data in ipairs(SavedOutfitsData) do
        local btnRow = Instance.new("Frame", SavedP)
        btnRow.Size = UDim2.new(1, -5, 0, 32)
        btnRow.BackgroundTransparency = 1
        table.insert(SavedUIRefs, btnRow)
        
        local loadBtn = Instance.new("TextButton", btnRow)
        loadBtn.Size = UDim2.new(0.8, -5, 1, 0)
        loadBtn.BackgroundColor3 = BordeauxColor
        loadBtn.Text = data.Name:upper()
        loadBtn.TextColor3 = Color3.new(1,1,1)
        loadBtn.Font = Enum.Font.GothamBold
        loadBtn.TextSize = 12
        Instance.new("UICorner", loadBtn).CornerRadius = UDim.new(0, 6)
        
        loadBtn.MouseButton1Click:Connect(function()
            applyOutfit(data.Shirt, data.Pants, false)
            if data.SkinColor then applySkin(d_Col(data.SkinColor), false) end
            CurrentAccArgs = deserializeAccArgs(data.AccArgs)
            if CurrentAccArgs then applyAcc(Player.Character, CurrentAccArgs) end
            if data.WeaponSkins then ActiveWeaponSkins = data.WeaponSkins else ActiveWeaponSkins = {} end
            updateGunButtonsUI()
            if data.LevelHidden ~= nil then LevelHidden = data.LevelHidden applyLevelHide() end
            if data.UIHidden ~= nil then UIHidden = data.UIHidden applyUIHide() end
            if data.StatsSpoofed ~= nil then StatsSpoofed = data.StatsSpoofed applyStatsSpoof() end
            if data.ClockTime ~= nil then applyLighting(data.ClockTime) else applyLighting(nil) end
            if data.IsHeadless ~= nil then IsHeadless = data.IsHeadless else IsHeadless = false end
            if data.IsLeftLegless ~= nil then IsLeftLegless = data.IsLeftLegless else IsLeftLegless = false end
            if data.ActiveCustomKillSound ~= nil then ActiveCustomKillSound = data.ActiveCustomKillSound else ActiveCustomKillSound = "NONE" end
            applyHeadless()
            applyLegless()
            applyKillSound()
            updateSoundUI()
        end)
        
        local delBtn = Instance.new("TextButton", btnRow)
        delBtn.Size = UDim2.new(0.2, 0, 1, 0)
        delBtn.Position = UDim2.new(0.8, 0, 0, 0)
        delBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        delBtn.Text = "X"
        delBtn.TextColor3 = Color3.new(1,1,1)
        delBtn.Font = Enum.Font.GothamBold
        Instance.new("UICorner", delBtn).CornerRadius = UDim.new(0, 6)

        delBtn.MouseButton1Click:Connect(function()
            table.remove(SavedOutfitsData, i)
            writeSaves()
            loadSavedButtons()
        end)
    end
end

