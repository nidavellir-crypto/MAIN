            if char and char:FindFirstChild(baseWepName) then table.insert(targets, char[baseWepName]) end
            if backpack and backpack:FindFirstChild(baseWepName) then table.insert(targets, backpack[baseWepName]) end
            if displayItems and displayItems:FindFirstChild(baseWepName) then table.insert(targets, displayItems[baseWepName]) end
            if repStorageModels and repStorageModels:FindFirstChild(baseWepName) then table.insert(targets, repStorageModels[baseWepName]) end

            for _, target in ipairs(targets) do
                local needsApply = false
                
                if target:GetAttribute("CustomSkinApplied") ~= activeSkinName then
                    needsApply = true
                else
                    if skinData.IsSpecial == "Mare_Trickshot" then
                        if not target:FindFirstChild("ModView_Trickshot") then
                            needsApply = true
                        else
                            local origHandle = target:FindFirstChild("Handle") or target:FindFirstChild("Base")
                            if origHandle and origHandle.Transparency < 1 then
                                needsApply = true
                            end
                        end
                    else
                        if not target:FindFirstChild("Custom_SurfaceAppearance", true) then
                            needsApply = true
                        end
                    end
                end

                if needsApply then
                    applyCustomWeaponSkin(target, skinData)
                    target:SetAttribute("CustomSkinApplied", activeSkinName)
                end
            end
        end
    end)
end)

