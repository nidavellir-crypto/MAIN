            obj.Transparency = IsLeftLegless and 1 or 0
        end
    end
end

-- === WEAPON SKIN LOGIC ===
local function applyCustomWeaponSkin(weapon, skinData)
    local applied = false

    if skinData.IsSpecial == "G17_Elim" then
        local SOUNDS = { Fire = "rbxassetid://3466984142", ReloadSlide = "rbxassetid://86227568494434" }
        local FIRE_SETTINGS = { PlaybackSpeed = 2.3, Volume = 0.8 }
        local RELOAD_SETTINGS = { PlaybackSpeed = 1.1, Volume = 1.5 }
        local BULLET_COLOR = Color3.fromRGB(175, 130, 140)
        local SIGHT_COLOR = Color3.fromRGB(255, 0, 127)

        for _, v in ipairs(weapon:GetDescendants()) do
            if v:IsA("MeshPart") or v:IsA("Part") then
                local name = v.Name:lower()
                for _, child in ipairs(v:GetChildren()) do
                    if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                        child:Destroy()
                    end
                end

                if name:find("sight") or name:find("iron") or name:find("dot") then
                    v.Color = SIGHT_COLOR
                    v.Material = Enum.Material.Neon
                    v.Transparency = 0
                elseif name:find("slide") or name:find("barrel") then
                    v.Color = Color3.new(0, 0, 0) 
                    v.Transparency = 0.4          
                    v.Material = Enum.Material.Plastic
                else
                    if v:IsA("MeshPart") then
                        local sa = Instance.new("SurfaceAppearance")
                        sa.Name = "Custom_SurfaceAppearance"
                        sa.ColorMap = skinData.ColorMap
                        sa.MetalnessMap = skinData.MetalnessMap
                        sa.NormalMap = skinData.NormalMap
                        sa.RoughnessMap = skinData.RoughnessMap
                        sa.Parent = v
                        v.Transparency = 0
                    end
                end
                applied = true
            elseif v:IsA("Sound") then
                local soundName = v.Name:lower()
                if soundName:find("fire") or soundName:find("shot") then
                    v.SoundId = SOUNDS.Fire
                    v.PlaybackSpeed = FIRE_SETTINGS.PlaybackSpeed
                    v.Volume = FIRE_SETTINGS.Volume
                elseif soundName:find("slide") or soundName:find("pull") or soundName:find("chamber") then
                    v.SoundId = SOUNDS.ReloadSlide
                    v.PlaybackSpeed = RELOAD_SETTINGS.PlaybackSpeed
                    v.Volume = RELOAD_SETTINGS.Volume
                end
            elseif v:IsA("BasePart") then
                if v.Name:lower():find("shell") or v.Name:lower():find("bullet") then
                    v.Color = BULLET_COLOR
                    v.Material = Enum.Material.Neon
                    if v:IsA("MeshPart") then v.TextureID = "" end
                    local sa = v:FindFirstChildOfClass("SurfaceAppearance")
                    if sa then sa:Destroy() end
                end
            end
        end
        return applied

    elseif skinData.IsSpecial == "Mare_Trickshot" then
        local container = weapon:FindFirstChild("ModView_Trickshot")
        for _, v in ipairs(weapon:GetDescendants()) do
            if v:IsA("BasePart") then
                if container and v:IsDescendantOf(container) then continue end
                v.Transparency = 1
                if v:IsA("MeshPart") then v.TextureID = "" end
                local sa = v:FindFirstChildOfClass("SurfaceAppearance")
                if sa then sa:Destroy() end
            end
        end

        if container then 
            container:Destroy()
            container = nil
        end 

        local SOUNDS = { Fire = "rbxassetid://5033272182" }
        local FIRE_SETTINGS = { PlaybackSpeed = 1.0, Volume = 1.5 }
        local RELOAD_SETTINGS = { PlaybackSpeed = 0.8, BassBoost = 24, EchoIntensity = 0.4 }

        local toolHandle = weapon:FindFirstChild("Handle") or weapon:FindFirstChildWhichIsA("BasePart")
        if not toolHandle then return false end

        container = Instance.new("Model")
        container.Name = "ModView_Trickshot"
        container.Parent = weapon

        for _, v in ipairs(weapon:GetDescendants()) do
            if v:IsA("Sound") then
                local soundName = v.Name:lower()
                if soundName:find("fire") or soundName:find("shoot") then
                    v.SoundId = SOUNDS.Fire
                    v.PlaybackSpeed = FIRE_SETTINGS.PlaybackSpeed
                    v.Volume = FIRE_SETTINGS.Volume
                elseif soundName:find("reload") or soundName:find("mag") or soundName:find("clip") then
                    v.PlaybackSpeed = RELOAD_SETTINGS.PlaybackSpeed
                    if not v:FindFirstChild("ReloadBassBoost") then
                        local eq = Instance.new("EqualizerSoundEffect")
                        eq.Name = "ReloadBassBoost"
                        eq.LowGain = RELOAD_SETTINGS.BassBoost
                        eq.MidGain = 0
                        eq.HighGain = -15
                        eq.Parent = v
                    end
                    if not v:FindFirstChild("ReloadEcho") then
                        local echo = Instance.new("EchoSoundEffect")
                        echo.Name = "ReloadEcho"
                        echo.Delay = 0.15
                        echo.Feedback = 0.3
                        echo.WetLevel = RELOAD_SETTINGS.EchoIntensity
                        echo.Parent = v
                    end
                end
            end
        end

        local rsStorage = game:GetService("ReplicatedStorage"):FindFirstChild("Storage")
        local customModelPath = rsStorage and rsStorage:FindFirstChild("SkinVariants") and rsStorage.SkinVariants:FindFirstChild("Guns") and rsStorage.SkinVariants.Guns:FindFirstChild("mare_trickshot")
        
        if customModelPath then
            local customGun = customModelPath:Clone()
            customGun.Parent = container

            for _, v in ipairs(customGun:GetDescendants()) do
                if v:IsA("BasePart") then
                    if v:IsA("MeshPart") or v:IsA("UnionOperation") or v:FindFirstChildWhichIsA("SpecialMesh") then
                        if not string.match(string.lower(v.Name), "hitbox") and not string.match(string.lower(v.Name), "invisible") then
                            v.Transparency = 0
                            v.LocalTransparencyModifier = 0
                        end
                    else
                        v.Transparency = 1
                    end
                end
            end

            local customHandle = customGun.PrimaryPart or customGun:FindFirstChild("Handle") or customGun:FindFirstChild("Base") or customGun:FindFirstChildWhichIsA("BasePart")
            if customHandle then
                container.PrimaryPart = customHandle 
                for _, v in ipairs(customGun:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.Massless = true
                        v.CanCollide = false
                        v.Anchored = false
                        if v ~= customHandle and not v:FindFirstChildWhichIsA("JointInstance") then
                            local internalWeld = Instance.new("WeldConstraint")
                            internalWeld.Part0 = customHandle
                            internalWeld.Part1 = v
                            internalWeld.Parent = v
                        end
                    end
                end
                customHandle.Massless = true
                customHandle.CanCollide = false
                customHandle.Anchored = false

                local offsetCFrame = CFrame.new(0, 0, 0)
                if customGun:IsA("Model") and customGun.PrimaryPart then
                    customGun:PivotTo(toolHandle.CFrame * offsetCFrame)
                else
                    customHandle.CFrame = toolHandle.CFrame * offsetCFrame
                end

                local weld = Instance.new("WeldConstraint")
                weld.Part0 = toolHandle
                weld.Part1 = customHandle
                weld.Parent = customHandle

                for _, part in ipairs(customGun:GetDescendants()) do
                    if part:IsA("MeshPart") then
                        for _, child in ipairs(part:GetChildren()) do
                            if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                                child:Destroy()
                            end
                        end
                        local sa = Instance.new("SurfaceAppearance")
                        sa.Name = "Custom_SurfaceAppearance"
                        sa.ColorMap = skinData.ColorMap
                        sa.MetalnessMap = skinData.MetalnessMap
                        sa.NormalMap = skinData.NormalMap
                        sa.RoughnessMap = skinData.RoughnessMap
                        sa.Parent = part
                    end
                end
            end
        else
            for _, v in ipairs(weapon:GetDescendants()) do
                if v:IsA("MeshPart") and not v:IsDescendantOf(container) then
                    v.Transparency = 0 
                    for _, child in ipairs(v:GetChildren()) do
                        if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                            child:Destroy()
                        end
                    end
                    local sa = Instance.new("SurfaceAppearance")
                    sa.Name = "Custom_SurfaceAppearance"
                    sa.ColorMap = skinData.ColorMap
                    sa.MetalnessMap = skinData.MetalnessMap
                    sa.NormalMap = skinData.NormalMap
                    sa.RoughnessMap = skinData.RoughnessMap
                    sa.Parent = v
                end
            end
        end

        return true
    end

    for _, part in ipairs(weapon:GetDescendants()) do
        if part:IsA("MeshPart") then
            for _, child in ipairs(part:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
            local sa = Instance.new("SurfaceAppearance")
            sa.Name = "Custom_SurfaceAppearance"
            sa.ColorMap = skinData.ColorMap
            sa.MetalnessMap = skinData.MetalnessMap
            sa.NormalMap = skinData.NormalMap
            sa.RoughnessMap = skinData.RoughnessMap
            sa.AlphaMode = Enum.AlphaMode.Overlay
            sa.Parent = part
            applied = true
        end
    end
   
    return applied
end

