end

-- === SOUND LOGIC (FIXED RANDOM MODE – EVERY KILL A NEW RANDOM SOUND) ===
local function applyKillSound()
    pcall(function()
        local storage = ReplicatedStorage:WaitForChild("Storage", 3)
        if not storage then return end
        local uiSounds = storage:WaitForChild("UISounds", 3)
        if not uiSounds then return end
        local killSound = uiSounds:WaitForChild("kill_sound", 3)
        
        if killSound then
            -- Clean up old hooks
            for _, conn in ipairs(KillSoundConnections) do
                conn:Disconnect()
            end
            table.clear(KillSoundConnections)

            if OriginalKillSoundId == "" then
                OriginalKillSoundId = killSound.SoundId
            end

            local isRandom = (ActiveCustomKillSound == "RANDOM")

            -- Helper to set a random custom sound
            local function setRandomSound()
                if #RandomSoundKeys == 0 then return end
                local key = RandomSoundKeys[math.random(#RandomSoundKeys)]
                local info = CUSTOM_KILL_SOUNDS[key]
                killSound.SoundId = info.Id
                killSound.TimePosition = info.Offset
            end

            if isRandom then
                -- Set initial random sound
                setRandomSound()

                -- After the kill sound finishes, prepare a fresh random sound for next time
                local endedConn = killSound.Ended:Connect(function()
                    if ActiveCustomKillSound ~= "RANDOM" then return end
                    setRandomSound()
                end)
                table.insert(KillSoundConnections, endedConn)

                -- Also listen if the game changes the SoundId (e.g., resets to default).
                -- If it's not already one of our custom sounds, replace it with a random one.
                local sidConn = killSound:GetPropertyChangedSignal("SoundId"):Connect(function()
                    if ActiveCustomKillSound ~= "RANDOM" then return end
                    local currentId = killSound.SoundId
                    for _, info in pairs(CUSTOM_KILL_SOUNDS) do
                        if currentId == info.Id then
                            return -- already a custom sound, leave it
                        end
                    end
                    setRandomSound()
                end)
                table.insert(KillSoundConnections, sidConn)

            elseif ActiveCustomKillSound ~= "NONE" then
                -- Fixed custom sound (non-random)
                local info = CUSTOM_KILL_SOUNDS[ActiveCustomKillSound]
                if info then
                    killSound.SoundId = info.Id
                    killSound.TimePosition = info.Offset
                end
                local conn1 = killSound:GetPropertyChangedSignal("SoundId"):Connect(function()
                    if ActiveCustomKillSound == "NONE" then return end
                    local info = CUSTOM_KILL_SOUNDS[ActiveCustomKillSound]
                    if info and killSound.SoundId ~= info.Id then
                        killSound.SoundId = info.Id
                        killSound.TimePosition = info.Offset
                    end
                end)
                table.insert(KillSoundConnections, conn1)
                local conn2 = killSound:GetPropertyChangedSignal("TimePosition"):Connect(function()
                    local info = CUSTOM_KILL_SOUNDS[ActiveCustomKillSound]
                    if info and killSound.TimePosition < info.Offset then
                        killSound.TimePosition = info.Offset
                    end
                end)
                table.insert(KillSoundConnections, conn2)
            else
                -- NONE mode
                killSound.SoundId = OriginalKillSoundId
            end
        end
    end)
end

