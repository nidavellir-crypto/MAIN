local function applyStatsSpoof()
    if StatsSpoofConnection then
        StatsSpoofConnection:Disconnect()
        StatsSpoofConnection = nil
    end

    if StatsSpoofed then
        StatsSpoofConnection = RunService.RenderStepped:Connect(function()
            pcall(function()
                local ClientFrame = Player.PlayerGui.CoreGUI.ClientFrame
                for _, original in ipairs(ClientFrame:GetDescendants()) do
                    if original:IsA("TextLabel") and not original:GetAttribute("NidavellirFake") then
                        local text = original.Text:lower()
                        if text:find("fps") then
                            original.TextTransparency = 1 
                            local fakeName = original.Name .. "_Shadow"
                            local shadow = original.Parent:FindFirstChild(fakeName)
                            if not shadow then
                                shadow = original:Clone()
                                shadow.Name = fakeName
                                shadow:SetAttribute("NidavellirFake", true)
                                shadow.Parent = original.Parent
                            end
                            shadow.Visible = true
                            shadow.TextTransparency = 0
                            shadow.Position = original.Position
                            shadow.Size = original.Size
                            shadow.Font = original.Font 
                            shadow.RichText = true
                            shadow.Text = "FPS: <b>999</b>"
                        end
                    end
                end
            end)
        end)
    else
        pcall(function()
            local ClientFrame = Player.PlayerGui.CoreGUI.ClientFrame
            for _, v in ipairs(ClientFrame:GetDescendants()) do
                if v:IsA("TextLabel") then
                    if v:GetAttribute("NidavellirFake") then
                        v:Destroy()
                    else
                        v.TextTransparency = 0
                    end
                end
            end
        end)
