local gunButtons = {}

local function updateGunButtonsUI()
    for name, data in pairs(gunButtons) do
        local base = string.split(name, " ")[1]
        if ActiveWeaponSkins[base] == name then
            data.Button.Text = name:upper() .. ": ON"
            data.Button.BackgroundColor3 = Color3.fromRGB(40, 100, 40)
        else
            data.Button.Text = name:upper() .. ": OFF"
            data.Button.BackgroundColor3 = BordeauxColor
        end
    end
end

for skinName, _ in pairs(WEAPON_SKINS) do
    local baseWepName = string.split(skinName, " ")[1] 
    local btn
    
    btn = createBtn(skinName:upper() .. ": OFF", BordeauxColor, GunP, function()
        if ActiveWeaponSkins[baseWepName] == skinName then
            ActiveWeaponSkins[baseWepName] = nil
        else
             ActiveWeaponSkins[baseWepName] = skinName
        end
        updateGunButtonsUI()
    end)
    gunButtons[skinName] = {Button = btn}
end

GunSearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    local searchText = string.lower(GunSearchBox.Text)
    for skinName, data in pairs(gunButtons) do
        data.Button.Visible = (searchText == "" or string.find(string.lower(skinName), searchText) ~= nil)
    end
end)

